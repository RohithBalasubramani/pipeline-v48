# ===== pipeline_v48 =====

# Python caches & test artifacts
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.hypothesis/
.coverage

# Node / Vite (host/web frontend)
node_modules/
host/web/dist/
.vite/
*.tsbuildinfo
*.tmp.*

# Built search index / local sqlite databases (regenerated by copilot/build)
*.sqlite
*.db

# Logs & heavy runtime output (regenerated on each run)
*.log
logs/
outputs/*.json
outputs/logs/
outputs/logs_*/
outputs/_log_archive/
outputs/fullsweep*/
outputs/replay*/
outputs/traces/
outputs/latency/
outputs/validation/
host/outputs/
.playwright-mcp/

# Env & secrets
.env
.env*.local

# Backup snapshots / archive tarballs (redundant with tracked sources)
archive/

# OS cruft
.DS_Store
host/web/cmd-v2-src
host/web/public/media/
